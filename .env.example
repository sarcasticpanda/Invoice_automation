# Copy to .env and fill in real values. NEVER commit the real .env.
# These are the variables the backend reads.

# Gmail account the email pipeline reads/sends from
MY_EMAIL=you@gmail.com

# Google Gemini (chat + email agents). gemini-2.5-flash is used by chat.
GOOGLE_API_KEY=

# Groq (only the legacy /api/rag-query test endpoint)
GROQ_API_KEY=

# Supabase — chat history. Backend uses URL + SERVICE_KEY (PostgREST).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Frontend (Vite) — only needed if the frontend talks to Supabase directly
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=
